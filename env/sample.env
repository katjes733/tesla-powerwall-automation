# Tesla Fleet API Configuration
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=http://localhost:3001/callback
TESLA_REFRESH_TOKEN=

# Tesla Fleet API Endpoints
TESLA_AUTH_BASE_URL=https://fleet-auth.prd.vn.cloud.tesla.com
TESLA_API_BASE_URL=https://fleet-api.prd.na.vn.cloud.tesla.com

# Whether or not to disable the scheduled jobs
SCHEDULED_JOBS_DISABLED=true

# Enable dry-run mode: schedules fire and are evaluated, but no write calls are sent to the Tesla API
DRY_RUN=false

# Redis (used to cache Tesla solar history API responses)
REDIS_HOST=localhost
REDIS_PORT=6379
# Redis AUTH — leave empty for no authentication (default for local dev).
# If set, docker-compose will start Redis with --requirepass automatically.
REDIS_PASSWORD=

# Session secret — required, must be a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Token encryption key — required, must be exactly 32 bytes hex (64 chars), e.g. openssl rand -hex 32
# WARNING: losing this key makes all stored Tesla refresh tokens unrecoverable; users would need to re-authenticate
TOKEN_ENCRYPTION_KEY=

# PostgreSQL TLS — set DB_SSL=true after running: bun run generate-certs
# See the "PostgreSQL TLS" section in README.md for setup instructions.
DB_SSL=false
DB_SSL_CA_PATH=./postgres/certs/ca.crt

# CORS — comma-separated list of browser origins allowed to call the API.
# Include both http:// and https:// variants if you run the app with SSL enabled.
# In production, set this to the URL (including port if non-standard) where the frontend is served.
ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173

# HTTPS / TLS (recommended for self-hosted production deployments)
# Set SSL_ENABLED=true and provide paths to a certificate and private key.
# For a self-signed certificate see the "HTTPS / Self-Signed Certificate" section in README.md.
SSL_ENABLED=false
SSL_KEY_PATH=ssl/key.pem
SSL_CERT_PATH=ssl/cert.pem

# WebAuthn (Face ID / Touch ID / Windows Hello passkey login) — required for that feature in production.
# WEBAUTHN_RP_ID must be a bare registrable domain (no scheme/port, never a raw IP — the WebAuthn
# spec rejects IP addresses). If the app is reachable at multiple subdomains of the same domain,
# set this to the shared parent domain so a passkey registered on one subdomain works on all of them.
# In development this defaults to "localhost" if left unset.
WEBAUTHN_RP_ID=
# Comma-separated list of full origins (scheme + host, no path) that are allowed to complete a
# WebAuthn ceremony — include every public hostname the app is reachable at.
# In development this defaults to https://localhost:5173 if left unset.
WEBAUTHN_EXPECTED_ORIGINS=
