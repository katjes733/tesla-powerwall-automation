{
  "name": "tesla-powerwall-automation",
  "version": "1.0.0",
  "description": "",
  "main": "main.ts",
  "type": "module",
  "bin": {
    "tesla-powerwall-automation": "build/main.js"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "docker:up": "docker-compose --env-file .env up -d",
    "docker:down": "docker-compose --env-file .env down",
    "build": "bun build src/server/main.ts --outdir build --target bun --minify",
    "eslint": "bun x eslint src tests",
    "eslint:fix": "bun eslint -- --quiet --fix",
    "generate-certs": "bash scripts/generate-certs.sh",
    "new-refresh-token": "bun run scripts/getNewRefreshToken.ts",
    "status": "bun run scripts/status.ts",
    "prettier": "bun x prettier --check src/* tests/*",
    "prettier:fix": "bun x prettier --write src/* tests/*",
    "start": "bun run src/server/main.ts",
    "dev:server": "cross-env NODE_ENV=development nodemon --watch src/server --watch .env --ext ts,env --exec 'bun run src/server/main.ts'",
    "stylelint": "stylelint 'src/**/*.{css,scss}' --allow-empty-input",
    "stylelint:fix": "bun run stylelint -- --fix",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:coverage:lcov": "bun test --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "lint": "bun run prettier && bun run eslint && bun run stylelint && bun run tsc",
    "tsc": "tsc --noEmit",
    "verify": "bun prettier && bun eslint && bun stylelint && bun tsc && bun test:coverage",
    "dev:client": "vite",
    "build-client": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "typescript",
    "bun",
    "tesla",
    "powerwall"
  ],
  "author": "",
  "license": "",
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/bun": "^1.2.18",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "^4.6.0",
    "bun-types": "^1.2.18",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "stylelint": "^16.21.1",
    "stylelint-config-standard": "^38.0.0",
    "typescript-eslint": "^8.36.0",
    "vite": "^7.0.4"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.2.0",
    "@mui/material": "^7.2.0",
    "@mui/x-data-grid": "^8.7.0",
    "argon2": "^0.43.0",
    "axios": "^1.18.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron-parser": "^5.3.0",
    "dedent": "^1.6.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "helmet": "^8.2.0",
    "http": "^0.0.1-security",
    "https": "^1.0.0",
    "ioredis": "^5.11.1",
    "jwt-decode": "^4.0.0",
    "moment-timezone": "^0.6.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "open": "^10.1.2",
    "otp-io": "^1.2.7",
    "pg": "^8.16.3",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.0.0",
    "rate-limit-redis": "^5.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.3",
    "typeorm": "^0.3.25",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  }
}
