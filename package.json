{
  "name": "tesla-powerwall-automation",
  "version": "1.0.0",
  "description": "",
  "main": "main.ts",
  "type": "module",
  "bin": {
    "tesla-powerwall-automation": "build/main.js"
  },
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"bun run dev:server\" \"bun run dev:client\"",
    "docker:up": "docker-compose --env-file .env up -d",
    "docker:down": "docker-compose --env-file .env down",
    "build": "bun build src/server/main.ts --outdir build --target bun --minify",
    "eslint": "bun x eslint src tests",
    "eslint:fix": "bun eslint -- --quiet --fix",
    "generate-certs": "bash scripts/generate-certs.sh",
    "new-refresh-token": "bun run scripts/getNewRefreshToken.ts",
    "status": "bun run scripts/status.ts",
    "prettier": "bun x prettier --check src/* tests/*",
    "prettier:fix": "bun x prettier --write src/* tests/*",
    "start": "bun run src/server/main.ts",
    "dev:server": "cross-env NODE_ENV=development nodemon --watch src/server --watch src/shared --watch .env --ext ts,env --exec 'bun src/server/main.ts'",
    "stylelint": "stylelint 'src/**/*.{css,scss}' --allow-empty-input",
    "stylelint:fix": "bun run stylelint -- --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:lcov": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov",
    "lint": "bun run prettier && bun run eslint && bun run stylelint && bun run tsc",
    "tsc": "tsc --noEmit",
    "verify": "bun prettier && bun eslint && bun stylelint && bun tsc && bun test:coverage && bun audit",
    "dev:client": "vite",
    "build-client": "tsc -b && vite build",
    "preview": "vite preview",
    "redis-commander": "bun run scripts/redis-commander.ts"
  },
  "files": [
    "build"
  ],
  "keywords": [
    "typescript",
    "bun",
    "tesla",
    "powerwall"
  ],
  "author": "katjes733",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "bun-types": "^1.3.14",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.11",
    "@mui/x-data-grid": "^8.29.1",
    "@mui/x-date-pickers": "^9.7.0",
    "argon2": "^0.44.0",
    "axios": "^1.18.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cron-parser": "^5.6.0",
    "dayjs": "^1.11.21",
    "dedent": "^1.7.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jwt-decode": "^4.0.0",
    "moment-timezone": "^0.6.2",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "open": "^11.0.0",
    "otp-io": "^1.2.7",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "rate-limit-redis": "^5.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.9.0",
    "typeorm": "^0.3.30",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "path-to-regexp": "8.4.2",
    "qs": "6.15.2",
    "fast-uri": "3.1.2",
    "flatted": "3.4.2",
    "yaml": "1.10.3",
    "picomatch": "2.3.2"
  }
}
